---
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { generateExcerpt, cleanWpContent } from '../../utils/content';
import { generateItemListSchema } from '../../utils/seo';
import postsData from '../../data/posts.json';

export function getStaticPaths() {
  const perPage = 24;
  const catMap: Record<string, string> = {
    'tiendas-chinas': 'Tiendas Chinas',
    'ropa': 'Ropa',
    'accesorios': 'Accesorios',
    'tecnologia': 'Tecnología',
    'calzado': 'Calzado',
    'deporte': 'Deporte',
    'blog': 'Blog',
    'xiaomi': 'Xiaomi',
  };

  const paths: any[] = [];

  for (const slug of Object.keys(catMap)) {
    const catName = catMap[slug];
    const catPosts = (postsData as any[]).filter(
      (post: any) => post.categories && post.categories.includes(catName)
    );
    const totalPages = Math.ceil(catPosts.length / perPage);

    // /categoria/slug (page 1)
    paths.push({
      params: { path: slug },
      props: { slug, currentPage: 1, totalPages },
    });

    // /categoria/slug/2, /categoria/slug/3, etc.
    for (let i = 2; i <= totalPages; i++) {
      paths.push({
        params: { path: `${slug}/${i}` },
        props: { slug, currentPage: i, totalPages },
      });
    }
  }

  return paths;
}

const POSTS_PER_PAGE = 24;

const categoryMap: Record<string, string> = {
  'tiendas-chinas': 'Tiendas Chinas',
  'ropa': 'Ropa',
  'accesorios': 'Accesorios',
  'tecnologia': 'Tecnología',
  'calzado': 'Calzado',
  'deporte': 'Deporte',
  'blog': 'Blog',
  'xiaomi': 'Xiaomi',
};

const categoryLabels: Record<string, string> = {
  'tiendas-chinas': 'Tiendas Chinas',
  'ropa': 'Ropa',
  'accesorios': 'Accesorios',
  'tecnologia': 'Tecnología',
  'calzado': 'Calzado',
  'deporte': 'Deporte',
  'blog': 'Blog',
  'xiaomi': 'Xiaomi',
};

// SEO descriptions for each category (shown as intro on page 1)
const categoryDescriptions: Record<string, string> = {
  'tiendas-chinas': 'Análisis y reseñas de las principales tiendas chinas online: AliExpress, Shein, TEMU, GearBest, Banggood y más. Comparativas, cupones y guías de compra.',
  'ropa': 'Las mejores tiendas chinas de ropa barata: Shein, AliExpress, Zaful y más. Guías de tallas, análisis de calidad y consejos para comprar ropa de China con garantías.',
  'accesorios': 'Accesorios de moda y hogar baratos en tiendas chinas. Bolsos, joyería, bisutería, decoración y mucho más a precios increíbles.',
  'tecnologia': 'Gadgets y tecnología barata de China: móviles, auriculares, smartwatches, drones y electrónica. Análisis honestos y guías de compra.',
  'calzado': 'Zapatillas y calzado chino de calidad: marcas, tallas y guías de compra para encontrar el mejor calzado a precio de China.',
  'deporte': 'Material deportivo y ropa de deporte barata en tiendas chinas. Análisis de equipamiento deportivo, zapatillas running y accesorios fitness.',
  'blog': 'Artículos generales sobre compras en China, consejos para importar, guías de aduanas y novedades del comercio chino online.',
  'xiaomi': 'Productos Xiaomi al mejor precio: móviles, accesorios, smartwatches, scooters y el ecosistema Xiaomi disponible en tiendas chinas.',
};

const { slug, currentPage, totalPages } = Astro.props;
const catName = categoryMap[slug!] || slug;
const catLabel = categoryLabels[slug!] || slug;

const allCatPosts = (postsData as any[]).filter(
  (post: any) => post.categories && post.categories.includes(catName)
);
const start = (currentPage - 1) * POSTS_PER_PAGE;
const paginatedPosts = allCatPosts.slice(start, start + POSTS_PER_PAGE);

const prevUrl = currentPage > 1 ? (currentPage === 2 ? `/categoria/${slug}` : `/categoria/${slug}/${currentPage - 1}`) : undefined;
const nextUrl = currentPage < totalPages ? `/categoria/${slug}/${currentPage + 1}` : undefined;

const siteUrl = 'https://decomprasporchina.com';
const itemListSchema = currentPage === 1 ? generateItemListSchema({
  name: catLabel,
  description: categoryDescriptions[slug!] || `Artículos sobre ${catLabel} en tiendas chinas.`,
  url: `${siteUrl}/categoria/${slug}`,
  items: allCatPosts.slice(0, 24).map((post: any, i: number) => ({
    title: post.title,
    slug: post.slug,
    position: i + 1,
  })),
}) : null;
---

<Base
  title={`${catLabel}${currentPage > 1 ? ` - Página ${currentPage}` : ''} - De Compras por China`}
  description={categoryDescriptions[slug!] || `Descubre los mejores artículos sobre ${catLabel.toLowerCase()} en tiendas chinas. ${allCatPosts.length} guías disponibles.`}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
  schema={itemListSchema ? [itemListSchema] : undefined}
>
  <div class="container">
    <Breadcrumbs items={[
      { name: 'Categorías', url: '/' },
      { name: catLabel, url: `/categoria/${slug}` },
    ]} />

    <header class="article-header">
      <h1>{catLabel}</h1>
      <p style="color:#666">{allCatPosts.length} artículos en esta categoría</p>
    </header>

    {currentPage === 1 && categoryDescriptions[slug!] && (
      <div class="category-intro" set:html={categoryDescriptions[slug!]} />
    )}

    <div class="card-grid">
      {paginatedPosts.map((post: any) => (
        <ArticleCard
          title={post.title}
          slug={post.slug}
          excerpt={post.seoDescription || post.excerpt || generateExcerpt(cleanWpContent(post.body || ''), 120)}
          featuredImage={post.featuredImage}
          date={post.date}
        />
      ))}
    </div>

    {totalPages > 1 && (
      <nav class="pagination" aria-label="Paginación">
        {currentPage > 1 && (
          <a href={currentPage === 2 ? `/categoria/${slug}` : `/categoria/${slug}/${currentPage - 1}`} class="pagination-btn">&laquo; Anterior</a>
        )}
        <span class="pagination-info">Página {currentPage} de {totalPages}</span>
        {currentPage < totalPages && (
          <a href={`/categoria/${slug}/${currentPage + 1}`} class="pagination-btn">Siguiente &raquo;</a>
        )}
      </nav>
    )}
  </div>
</Base>
