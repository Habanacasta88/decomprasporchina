---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TableOfContents from '../components/TableOfContents.astro';
import AdUnit from '../components/AdUnit.astro';
import AffiliateBox from '../components/AffiliateBox.astro';
import { resolveYoastTitle, resolveYoastDescription, generateArticleSchema, generateFAQSchema } from '../utils/seo';
import { cleanWpContent, extractHeadings, addHeadingIds, generateExcerpt, extractFAQs, addInternalLinks } from '../utils/content';
import pagesData from '../data/pages.json';
import postsData from '../data/posts.json';

// ─── Affiliate links ───
const ALIEXPRESS = 'https://s.click.aliexpress.com/e/_c45uyDgx';
const AMAZON_TAG = 'enjoys0d-21';
const amz = (asin: string) => `https://www.amazon.es/dp/${asin}?tag=${AMAZON_TAG}`;

// ─── Contextual affiliate CTAs by category ───
// Each provides genuine value: the CTA matches what the reader is looking for.
type AffiliateCTA = {
  headline: string;
  description: string;
  ctaText: string;
  ctaUrl: string;
  secondaryCta?: { text: string; url: string };
  platform: 'aliexpress' | 'amazon' | 'both';
};

const categoryAffiliates: Record<string, AffiliateCTA> = {
  'Ropa': {
    headline: 'Encuentra ropa a precios de fabrica',
    description: 'Miles de vendedores verificados en AliExpress con ropa de tendencia desde 3\u20AC. Envio gratuito en la mayoria de articulos.',
    ctaText: 'Explorar ropa en AliExpress',
    ctaUrl: ALIEXPRESS,
    secondaryCta: { text: 'Ver moda en Amazon', url: `https://www.amazon.es/s?k=ropa+mujer+tendencia&tag=${AMAZON_TAG}` },
    platform: 'both',
  },
  'Calzado': {
    headline: 'Zapatillas y calzado al mejor precio',
    description: 'Compara precios entre AliExpress y Amazon para encontrar las mejores ofertas en zapatillas, botas y zapatos.',
    ctaText: 'Ver calzado en AliExpress',
    ctaUrl: ALIEXPRESS,
    secondaryCta: { text: 'Zapatillas en Amazon', url: `https://www.amazon.es/s?k=zapatillas+deportivas&tag=${AMAZON_TAG}` },
    platform: 'both',
  },
  'Tecnología': {
    headline: 'Gadgets y electronica desde China',
    description: 'Los ultimos gadgets, accesorios para movil y electronica de consumo a una fraccion de su precio habitual.',
    ctaText: 'Explorar tecnologia en AliExpress',
    ctaUrl: ALIEXPRESS,
    secondaryCta: { text: 'Gadgets en Amazon', url: `https://www.amazon.es/s?k=gadgets+tecnologia&tag=${AMAZON_TAG}` },
    platform: 'both',
  },
  'Accesorios': {
    headline: 'Accesorios originales a precios increibles',
    description: 'Desde bisuteria hasta accesorios para el hogar: descubre miles de opciones con envio gratuito.',
    ctaText: 'Ver accesorios en AliExpress',
    ctaUrl: ALIEXPRESS,
    secondaryCta: { text: 'Accesorios en Amazon', url: `https://www.amazon.es/s?k=accesorios+originales&tag=${AMAZON_TAG}` },
    platform: 'both',
  },
  'Deporte': {
    headline: 'Equipamiento deportivo a precio de China',
    description: 'Ropa tecnica, material de senderismo, zapatillas de deporte y equipamiento para cualquier actividad.',
    ctaText: 'Ver deporte en AliExpress',
    ctaUrl: ALIEXPRESS,
    secondaryCta: { text: 'Material deportivo en Amazon', url: `https://www.amazon.es/s?k=material+deportivo&tag=${AMAZON_TAG}` },
    platform: 'both',
  },
  'Xiaomi': {
    headline: 'Productos Xiaomi al mejor precio',
    description: 'Moviles, wearables, accesorios para el hogar inteligente y gadgets del ecosistema Xiaomi.',
    ctaText: 'Xiaomi en AliExpress',
    ctaUrl: ALIEXPRESS,
    secondaryCta: { text: 'Xiaomi en Amazon', url: `https://www.amazon.es/s?k=xiaomi&tag=${AMAZON_TAG}` },
    platform: 'both',
  },
  'Tiendas Chinas': {
    headline: 'Compra con confianza en tiendas chinas',
    description: 'AliExpress es la plataforma mas popular para comprar desde China, con proteccion al comprador y envio gratuito.',
    ctaText: 'Ir a AliExpress',
    ctaUrl: ALIEXPRESS,
    platform: 'aliexpress',
  },
  'Blog': {
    headline: 'Ahorra comprando en tiendas chinas',
    description: 'Descubre las mejores ofertas en AliExpress: ropa, tecnologia, accesorios y mucho mas con envio gratuito.',
    ctaText: 'Explorar AliExpress',
    ctaUrl: ALIEXPRESS,
    platform: 'aliexpress',
  },
};

// Specific overrides for high-traffic posts (matched by slug)
const slugAffiliates: Record<string, AffiliateCTA> = {
  'escoger-tu-talla-ropa-china': {
    headline: 'Ya sabes tu talla? Encuentra tu ropa ideal',
    description: 'Ahora que conoces tu equivalencia de tallas, explora miles de prendas en AliExpress con envio gratuito. Tambien puedes encontrar cintas metricas profesionales en Amazon para medir con precision.',
    ctaText: 'Comprar ropa en AliExpress',
    ctaUrl: ALIEXPRESS,
    secondaryCta: { text: 'Cinta metrica en Amazon', url: amz('B07GBLFPQN') },
    platform: 'both',
  },
  'zapatillas-nike-replicas': {
    headline: 'Las mejores zapatillas a precios imbatibles',
    description: 'Explora zapatillas deportivas de calidad en AliExpress. Amplio catalogo con proteccion al comprador y devolucion gratuita.',
    ctaText: 'Ver zapatillas en AliExpress',
    ctaUrl: ALIEXPRESS,
    secondaryCta: { text: 'Nike en Amazon', url: `https://www.amazon.es/s?k=zapatillas+nike&tag=${AMAZON_TAG}` },
    platform: 'both',
  },
  'las-mejores-zapatillas-de-deporte-en-aliexpress': {
    headline: 'Zapatillas de deporte desde 15\u20AC',
    description: 'Las marcas deportivas mas populares en AliExpress, con valoraciones reales de compradores y envio gratuito a Europa.',
    ctaText: 'Ver zapatillas de deporte',
    ctaUrl: ALIEXPRESS,
    secondaryCta: { text: 'Zapatillas running en Amazon', url: `https://www.amazon.es/s?k=zapatillas+running&tag=${AMAZON_TAG}` },
    platform: 'both',
  },
  'vestidos-de-fiesta-en-aliexpress': {
    headline: 'Vestidos de fiesta desde 12\u20AC',
    description: 'Cientos de modelos exclusivos en AliExpress: largos, cortos, con lentejuelas o encaje. Envio gratuito y proteccion al comprador.',
    ctaText: 'Ver vestidos de fiesta',
    ctaUrl: ALIEXPRESS,
    secondaryCta: { text: 'Vestidos en Amazon', url: `https://www.amazon.es/s?k=vestidos+fiesta+mujer&tag=${AMAZON_TAG}` },
    platform: 'both',
  },
  'muneca-de-silicona': {
    headline: 'Compara precios antes de decidir',
    description: 'Amazon ofrece envio rapido y devolucion facil en este tipo de productos. Compara opciones y elige la mejor relacion calidad-precio.',
    ctaText: 'Ver opciones en Amazon',
    ctaUrl: `https://www.amazon.es/s?k=mu%C3%B1eca+silicona+realista&tag=${AMAZON_TAG}`,
    platform: 'amazon',
  },
};

export function getStaticPaths() {
  const all = [...pagesData, ...postsData];
  return all.map((entry: any) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: any };

const cleaned = cleanWpContent(entry.body || '');
const linkedContent = entry.type === 'post' ? addInternalLinks(cleaned, entry.slug) : cleaned;
const htmlContent = addHeadingIds(linkedContent);
const headings = extractHeadings(cleaned);

const seoTitle = resolveYoastTitle(entry.seoTitle || '', entry.title);
const seoDescFallback = generateExcerpt(cleaned, 160);
const seoDesc = resolveYoastDescription(entry.seoDescription || '', entry.excerpt || seoDescFallback);

const siteUrl = 'https://decomprasporchina.com';
const articleSchema = generateArticleSchema({
  title: seoTitle,
  description: seoDesc,
  url: `${siteUrl}/${entry.slug}`,
  image: entry.featuredImage ? `${siteUrl}${entry.featuredImage}` : undefined,
  datePublished: entry.date,
  dateModified: entry.modified,
});

const formattedDate = new Date(entry.date).toLocaleDateString('es-ES', {
  day: 'numeric', month: 'long', year: 'numeric'
});
const formattedModified = new Date(entry.modified).toLocaleDateString('es-ES', {
  day: 'numeric', month: 'long', year: 'numeric'
});

const isLegal = entry.slug === 'politica-de-cookies' || entry.slug === 'politica-de-privacidad';

// Resolve affiliate CTA: slug-specific override > category match > null
const affiliateCTA: AffiliateCTA | null = isLegal ? null
  : slugAffiliates[entry.slug]
    ?? (entry.categories?.[0] ? categoryAffiliates[entry.categories[0]] : null)
    ?? categoryAffiliates['Blog'];

// FAQ data for visual rendering + structured data
const faqs = entry.type === 'post' && !isLegal ? extractFAQs(cleaned) : [];

// Compose schemas — BreadcrumbList is injected by Breadcrumbs.astro component
const faqSchema = faqs.length > 0 ? generateFAQSchema(faqs) : null;
const schemas = [articleSchema, ...(faqSchema ? [faqSchema] : [])];

// AdSense slot IDs — update with your actual slot IDs from AdSense dashboard
const AD_SLOT_AFTER_P1 = '4427222054';
const AD_SLOT_AFTER_P3 = '1879548363';

// Split HTML at the Nth closing </p> tag for ad injection
function splitAtParagraph(html: string, n: number): [string, string] {
  let count = 0;
  let idx = 0;
  while (idx < html.length) {
    const end = html.indexOf('</p>', idx);
    if (end === -1) break;
    count++;
    if (count === n) return [html.slice(0, end + 4), html.slice(end + 4)];
    idx = end + 4;
  }
  return [html, ''];
}

const isPost = entry.type === 'post' && !isLegal;
const [contentPart1, contentRest1] = isPost ? splitAtParagraph(htmlContent, 1) : [htmlContent, ''];
const [contentPart2, contentPart3] = isPost && contentRest1 ? splitAtParagraph(contentRest1, 2) : [contentRest1, ''];

// Slugs to noindex (duplicate content)
const duplicateSlugs = new Set<string>([]);
// Slugs to noindex (low value / very low traffic)
const lowTrafficSlugs = new Set<string>([]);

const isDuplicate = duplicateSlugs.has(entry.slug);
const isLowTraffic = lowTrafficSlugs.has(entry.slug);
const canonicalSlug = isDuplicate ? entry.slug.replace(/-\d+$/, '') : entry.slug;
const canonicalUrl = isDuplicate ? `${siteUrl}/${canonicalSlug}` : undefined;
---

<Base
  title={seoTitle}
  description={seoDesc}
  ogImage={entry.featuredImage}
  schema={schemas}
  ogType={entry.type === 'post' ? 'article' : 'website'}
  noindex={isDuplicate || isLowTraffic}
  canonicalUrl={canonicalUrl}
  articlePublished={entry.type === 'post' ? entry.date : undefined}
  articleModified={entry.type === 'post' ? (entry.modified || entry.date) : undefined}
>
  <div class="container">
    <Breadcrumbs items={[
      ...(entry.type === 'post' ? [{ name: 'Blog', url: '/blog' }] : []),
      { name: entry.title, url: `/${entry.slug}` },
    ]} />

    <div class={headings.length >= 3 && !isLegal ? 'article-layout' : ''}>
      <article>
        <header class="article-header">
          {entry.categories?.[0] && !isLegal && (
            <a href={`/categoria/${entry.categories[0].toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/\s+/g, '-')}`} class="article-cat-tag">
              {entry.categories[0]}
            </a>
          )}
          <h1>{entry.title}</h1>
          {!isLegal && (
            <div class="article-meta">
              <time datetime={entry.date}>{formattedDate}</time>
              {entry.date !== entry.modified && (
                <>
                  <span class="article-meta-sep">·</span>
                  <span>Actualizado: {formattedModified}</span>
                </>
              )}
            </div>
          )}
        </header>

        {entry.featuredImage && !isLegal && (
          <div class="article-featured-img">
            <img
              src={entry.featuredImage}
              alt={entry.title}
              width="1100"
              height="619"
              loading="eager"
            />
          </div>
        )}

        {headings.length < 3 && !isLegal && <TableOfContents headings={headings} />}

        <div class="article-content">
          <div set:html={contentPart1} />
          {isPost && <AdUnit slot={AD_SLOT_AFTER_P1} />}
          {contentPart2 && <div set:html={contentPart2} />}
          {affiliateCTA && <AffiliateBox
            headline={affiliateCTA.headline}
            description={affiliateCTA.description}
            ctaText={affiliateCTA.ctaText}
            ctaUrl={affiliateCTA.ctaUrl}
            secondaryCta={affiliateCTA.secondaryCta}
            platform={affiliateCTA.platform}
          />}
          {isPost && contentPart3 && <AdUnit slot={AD_SLOT_AFTER_P3} />}
          {contentPart3 && <div set:html={contentPart3} />}
        </div>

        {faqs.length >= 1 && !isLegal && (
          <section class="faq-section" aria-label="Preguntas frecuentes">
            <h2 class="faq-heading">Preguntas frecuentes</h2>
            {faqs.map((faq, i) => (
              <details class="faq-item" open={i === 0}>
                <summary class="faq-question">¿{faq.question}?</summary>
                <div class="faq-answer"><p>{faq.answer}</p></div>
              </details>
            ))}
          </section>
        )}

        {entry.type === 'post' && !isLegal && (() => {
          const related = (postsData as any[])
            .filter((p: any) =>
              p.slug !== entry.slug &&
              p.categories?.some((c: string) => entry.categories?.includes(c))
            )
            .slice(0, 4);
          return related.length > 0 ? (
            <aside class="related-posts">
              <h3 class="related-heading">📖 Artículos relacionados</h3>
              <ul class="related-list">
                {related.map((p: any) => (
                  <li><a href={`/${p.slug}`}>{p.title}</a></li>
                ))}
              </ul>
            </aside>
          ) : null;
        })()}
      </article>

      {headings.length >= 3 && !isLegal && (
        <aside class="article-sidebar">
          <TableOfContents headings={headings} />
        </aside>
      )}
    </div>
  </div>
</Base>
