---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TableOfContents from '../components/TableOfContents.astro';
import AffiliateCTA from '../components/AffiliateCTA.astro';
import { resolveYoastTitle, resolveYoastDescription, generateArticleSchema } from '../utils/seo';
import { cleanWpContent, extractHeadings, addHeadingIds, generateExcerpt, extractFAQs, addInternalLinks } from '../utils/content';
import pagesData from '../data/pages.json';
import postsData from '../data/posts.json';

export function getStaticPaths() {
  const all = [...pagesData, ...postsData];
  return all.map((entry: any) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: any };

const cleaned = cleanWpContent(entry.body || '');
const linkedContent = entry.type === 'post' ? addInternalLinks(cleaned, entry.slug) : cleaned;
const htmlContent = addHeadingIds(linkedContent);
const headings = extractHeadings(cleaned);

const seoTitle = resolveYoastTitle(entry.seoTitle || '', entry.title);
const seoDescFallback = generateExcerpt(cleaned, 160);
const seoDesc = resolveYoastDescription(entry.seoDescription || '', entry.excerpt || seoDescFallback);

const siteUrl = 'https://decomprasporchina.com';
const articleSchema = generateArticleSchema({
  title: seoTitle,
  description: seoDesc,
  url: `${siteUrl}/${entry.slug}`,
  image: entry.featuredImage ? `${siteUrl}${entry.featuredImage}` : undefined,
  datePublished: entry.date,
  dateModified: entry.modified,
});

const formattedDate = new Date(entry.date).toLocaleDateString('es-ES', {
  day: 'numeric', month: 'long', year: 'numeric'
});
const formattedModified = new Date(entry.modified).toLocaleDateString('es-ES', {
  day: 'numeric', month: 'long', year: 'numeric'
});

const isLegal = entry.slug === 'politica-de-cookies' || entry.slug === 'politica-de-privacidad';

// FAQ data for visual rendering (no JSON-LD — restricted to gov/healthcare)
const faqs = entry.type === 'post' && !isLegal ? extractFAQs(cleaned) : [];

// Compose schemas — BreadcrumbList is injected by Breadcrumbs.astro component
const schemas = [articleSchema];

// Detect duplicate posts by title — noindex all but the first occurrence
const duplicateSlugs = new Set([
  'como-cambiar-la-bateria-de-la-llave-de-un-auto-toyota-2',
  'como-cambiar-la-bateria-de-la-llave-de-un-auto-toyota-3',
  'como-cambiar-la-bateria-de-un-llavero-nissan-3',
  'como-cambiar-la-bateria-del-llavero-2',
  'como-cambiar-la-bateria-del-llavero-3',
  'como-cambiar-la-bateria-en-un-llavero-de-audi-2',
  'como-cambiar-la-bateria-en-un-llavero-mitsubishi-2',
  'como-cambiar-la-bateria-en-un-llavero-lincoln-2',
  'como-cambiar-la-bateria-en-un-llavero-lincoln-3',
  'como-cambiar-la-bateria-en-un-llavero-lincoln-4',
  'como-cambiar-la-bateria-en-un-llavero-toyota-2',
  'como-cambiar-la-bateria-en-un-llavero-2',
  'como-cambiar-la-bateria-en-un-llavero-3',
  'como-cambiar-la-bateria-en-un-llavero-4',
  'como-cambiar-la-bateria-en-un-llavero-5',
  'como-cambiar-la-bateria-en-un-llavero-6',
  'como-cambiar-la-bateria-en-un-llavero-subaru-2',
  'como-cambiar-la-bateria-de-un-llavero-ford-2',
  'como-cambiar-la-bateria-de-un-llavero-ford-3',
  'como-cambiar-la-bateria-de-la-llave-del-coche-2',
  'como-cambiar-la-bateria-en-un-llavero-cadillac-2',
  'como-cambiar-la-bateria-de-una-llave-vw-2',
  'como-cambio-la-bateria-de-mi-llavero-2',
  'como-cambio-la-bateria-de-mi-llavero-3',
  'como-cambiar-la-bateria-en-un-llavero-chevy-2',
  'como-cambiar-la-bateria-en-una-llave-nissan-2',
  'como-cambiar-la-bateria-en-un-llavero-volkswagen-2',
  'como-cambiar-la-bateria-en-un-llavero-hyundai-2',
  'como-cambiar-la-bateria-en-un-llavero-hyundai-3',
  'como-cambiar-la-bateria-en-un-llavero-vw-2',
]);
// Posts about brands not sold in Spain — noindex to avoid diluting ES authority
const lowTrafficSlugs = new Set([
  'como-reemplazar-la-bateria-en-el-llavero-de-chevy',
  'como-cambiar-la-bateria-en-un-llavero-chevy',
  'como-cambiar-la-bateria-en-un-llavero-lincoln',
  'como-cambiar-la-bateria-en-un-llavero-cadillac',
  'como-cambiar-la-bateria-de-una-llave-holden',
]);

const isDuplicate = duplicateSlugs.has(entry.slug);
const isLowTraffic = lowTrafficSlugs.has(entry.slug);
const canonicalSlug = isDuplicate ? entry.slug.replace(/-\d+$/, '') : entry.slug;
const canonicalUrl = isDuplicate ? `${siteUrl}/${canonicalSlug}` : undefined;
---

<Base
  title={seoTitle}
  description={seoDesc}
  ogImage={entry.featuredImage}
  schema={schemas}
  ogType={entry.type === 'post' ? 'article' : 'website'}
  noindex={isDuplicate || isLowTraffic}
  canonicalUrl={canonicalUrl}
  articlePublished={entry.type === 'post' ? entry.date : undefined}
  articleModified={entry.type === 'post' ? (entry.modified || entry.date) : undefined}
>
  <div class="container">
    <Breadcrumbs items={[
      ...(entry.type === 'post' ? [{ name: 'Blog', url: '/blog' }] : []),
      { name: entry.title, url: `/${entry.slug}` },
    ]} />

    <article>
      <header class="article-header">
        <h1>{entry.title}</h1>
        {!isLegal && (
          <div class="article-meta">
            <span>Publicado: {formattedDate}</span>
            {entry.date !== entry.modified && <span>Actualizado: {formattedModified}</span>}
          </div>
        )}
      </header>

      {entry.featuredImage && !isLegal && (
        <div class="article-featured-img">
          <img
            src={entry.featuredImage}
            alt={entry.title}
            width="1100"
            height="619"
            loading="eager"
          />
        </div>
      )}

      {!isLegal && <TableOfContents headings={headings} />}

      <div class="article-content" set:html={htmlContent} />

      {entry.type === 'post' && !isLegal && (
        <AffiliateCTA title={entry.title} categories={entry.categories} />
      )}

      {faqs.length >= 1 && !isLegal && (
        <section class="faq-section" aria-label="Preguntas frecuentes">
          <h2 class="faq-heading">Preguntas frecuentes</h2>
          {faqs.map((faq, i) => (
            <details class="faq-item" open={i === 0}>
              <summary class="faq-question">¿{faq.question}?</summary>
              <div class="faq-answer"><p>{faq.answer}</p></div>
            </details>
          ))}
        </section>
      )}
    </article>

    {entry.type === 'post' && !isLegal && (() => {
      // Priority: same category + noindex=false posts first
      const duplicateSet = new Set([
        'como-cambiar-la-bateria-de-la-llave-de-un-auto-toyota-2','como-cambiar-la-bateria-de-la-llave-de-un-auto-toyota-3',
        'como-cambiar-la-bateria-de-un-llavero-nissan-3','como-cambiar-la-bateria-del-llavero-2','como-cambiar-la-bateria-del-llavero-3',
        'como-cambiar-la-bateria-en-un-llavero-de-audi-2','como-cambiar-la-bateria-en-un-llavero-mitsubishi-2',
        'como-cambiar-la-bateria-en-un-llavero-lincoln-2','como-cambiar-la-bateria-en-un-llavero-lincoln-3','como-cambiar-la-bateria-en-un-llavero-lincoln-4',
        'como-cambiar-la-bateria-en-un-llavero-toyota-2','como-cambiar-la-bateria-en-un-llavero-2','como-cambiar-la-bateria-en-un-llavero-3',
        'como-cambiar-la-bateria-en-un-llavero-4','como-cambiar-la-bateria-en-un-llavero-5','como-cambiar-la-bateria-en-un-llavero-6',
        'como-cambiar-la-bateria-en-un-llavero-subaru-2','como-cambiar-la-bateria-de-un-llavero-ford-2','como-cambiar-la-bateria-de-un-llavero-ford-3',
        'como-cambiar-la-bateria-de-la-llave-del-coche-2','como-cambiar-la-bateria-en-un-llavero-cadillac-2','como-cambiar-la-bateria-de-una-llave-vw-2',
        'como-cambio-la-bateria-de-mi-llavero-2','como-cambio-la-bateria-de-mi-llavero-3','como-cambiar-la-bateria-en-un-llavero-chevy-2',
        'como-cambiar-la-bateria-en-una-llave-nissan-2','como-cambiar-la-bateria-en-un-llavero-volkswagen-2',
        'como-cambiar-la-bateria-en-un-llavero-hyundai-2','como-cambiar-la-bateria-en-un-llavero-hyundai-3','como-cambiar-la-bateria-en-un-llavero-vw-2',
      ]);
      const related = (postsData as any[])
        .filter((p: any) =>
          p.slug !== entry.slug &&
          !duplicateSet.has(p.slug) &&
          p.categories?.some((c: string) => entry.categories?.includes(c))
        )
        .slice(0, 4);
      return related.length > 0 ? (
        <aside class="related-posts">
          <h3 class="related-heading">Artículos relacionados</h3>
          <ul class="related-list">
            {related.map((p: any) => (
              <li>
                <a href={`/${p.slug}`}>{p.title}</a>
              </li>
            ))}
          </ul>
        </aside>
      ) : null;
    })()}
  </div>
</Base>
