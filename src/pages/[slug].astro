---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { resolveYoastTitle, resolveYoastDescription, generateArticleSchema } from '../utils/seo';
import { cleanWpContent, extractHeadings, addHeadingIds, generateExcerpt, extractFAQs, addInternalLinks } from '../utils/content';
import pagesData from '../data/pages.json';
import postsData from '../data/posts.json';

export function getStaticPaths() {
  const all = [...pagesData, ...postsData];
  return all.map((entry: any) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: any };

const cleaned = cleanWpContent(entry.body || '');
const linkedContent = entry.type === 'post' ? addInternalLinks(cleaned, entry.slug) : cleaned;
const htmlContent = addHeadingIds(linkedContent);
const headings = extractHeadings(cleaned);

const seoTitle = resolveYoastTitle(entry.seoTitle || '', entry.title);
const seoDescFallback = generateExcerpt(cleaned, 160);
const seoDesc = resolveYoastDescription(entry.seoDescription || '', entry.excerpt || seoDescFallback);

const siteUrl = 'https://decomprasporchina.com';
const articleSchema = generateArticleSchema({
  title: seoTitle,
  description: seoDesc,
  url: `${siteUrl}/${entry.slug}`,
  image: entry.featuredImage ? `${siteUrl}${entry.featuredImage}` : undefined,
  datePublished: entry.date,
  dateModified: entry.modified,
});

const formattedDate = new Date(entry.date).toLocaleDateString('es-ES', {
  day: 'numeric', month: 'long', year: 'numeric'
});
const formattedModified = new Date(entry.modified).toLocaleDateString('es-ES', {
  day: 'numeric', month: 'long', year: 'numeric'
});

const isLegal = entry.slug === 'politica-de-cookies' || entry.slug === 'politica-de-privacidad';

// FAQ data for visual rendering (no JSON-LD — restricted to gov/healthcare)
const faqs = entry.type === 'post' && !isLegal ? extractFAQs(cleaned) : [];

// Compose schemas — BreadcrumbList is injected by Breadcrumbs.astro component
const schemas = [articleSchema];

// Slugs to noindex (duplicate content)
const duplicateSlugs = new Set<string>([]);
// Slugs to noindex (low value / very low traffic)
const lowTrafficSlugs = new Set<string>([]);

const isDuplicate = duplicateSlugs.has(entry.slug);
const isLowTraffic = lowTrafficSlugs.has(entry.slug);
const canonicalSlug = isDuplicate ? entry.slug.replace(/-\d+$/, '') : entry.slug;
const canonicalUrl = isDuplicate ? `${siteUrl}/${canonicalSlug}` : undefined;
---

<Base
  title={seoTitle}
  description={seoDesc}
  ogImage={entry.featuredImage}
  schema={schemas}
  ogType={entry.type === 'post' ? 'article' : 'website'}
  noindex={isDuplicate || isLowTraffic}
  canonicalUrl={canonicalUrl}
  articlePublished={entry.type === 'post' ? entry.date : undefined}
  articleModified={entry.type === 'post' ? (entry.modified || entry.date) : undefined}
>
  <div class="container">
    <Breadcrumbs items={[
      ...(entry.type === 'post' ? [{ name: 'Blog', url: '/blog' }] : []),
      { name: entry.title, url: `/${entry.slug}` },
    ]} />

    <div class={headings.length >= 3 && !isLegal ? 'article-layout' : ''}>
      <article>
        <header class="article-header">
          {entry.categories?.[0] && !isLegal && (
            <a href={`/categoria/${entry.categories[0].toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/\s+/g, '-')}`} class="article-cat-tag">
              {entry.categories[0]}
            </a>
          )}
          <h1>{entry.title}</h1>
          {!isLegal && (
            <div class="article-meta">
              <time datetime={entry.date}>{formattedDate}</time>
              {entry.date !== entry.modified && (
                <>
                  <span class="article-meta-sep">·</span>
                  <span>Actualizado: {formattedModified}</span>
                </>
              )}
            </div>
          )}
        </header>

        {entry.featuredImage && !isLegal && (
          <div class="article-featured-img">
            <img
              src={entry.featuredImage}
              alt={entry.title}
              width="1100"
              height="619"
              loading="eager"
            />
          </div>
        )}

        {headings.length < 3 && !isLegal && <TableOfContents headings={headings} />}

        <div class="article-content" set:html={htmlContent} />

        {faqs.length >= 1 && !isLegal && (
          <section class="faq-section" aria-label="Preguntas frecuentes">
            <h2 class="faq-heading">Preguntas frecuentes</h2>
            {faqs.map((faq, i) => (
              <details class="faq-item" open={i === 0}>
                <summary class="faq-question">¿{faq.question}?</summary>
                <div class="faq-answer"><p>{faq.answer}</p></div>
              </details>
            ))}
          </section>
        )}

        {entry.type === 'post' && !isLegal && (() => {
          const related = (postsData as any[])
            .filter((p: any) =>
              p.slug !== entry.slug &&
              p.categories?.some((c: string) => entry.categories?.includes(c))
            )
            .slice(0, 4);
          return related.length > 0 ? (
            <aside class="related-posts">
              <h3 class="related-heading">📖 Artículos relacionados</h3>
              <ul class="related-list">
                {related.map((p: any) => (
                  <li><a href={`/${p.slug}`}>{p.title}</a></li>
                ))}
              </ul>
            </aside>
          ) : null;
        })()}
      </article>

      {headings.length >= 3 && !isLegal && (
        <aside class="article-sidebar">
          <TableOfContents headings={headings} />
        </aside>
      )}
    </div>
  </div>
</Base>
