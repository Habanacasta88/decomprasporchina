---
/**
 * AffiliateBox — Elegant product recommendation CTA.
 * Appears after article content, contextual to the category.
 * Uses rel="nofollow sponsored" for legal compliance.
 */
export interface Props {
  headline: string;
  description: string;
  ctaText: string;
  ctaUrl: string;
  secondaryCta?: { text: string; url: string };
  platform: 'aliexpress' | 'amazon' | 'both';
}

const { headline, description, ctaText, ctaUrl, secondaryCta, platform } = Astro.props;
---

<aside class="affiliate-box" aria-label="Recomendación">
  <div class="affiliate-box__badge">
    {platform === 'amazon' ? 'Recomendado en Amazon' : platform === 'both' ? 'Mejores precios' : 'Encuentra en AliExpress'}
  </div>
  <h3 class="affiliate-box__headline">{headline}</h3>
  <p class="affiliate-box__desc">{description}</p>
  <div class="affiliate-box__actions">
    <a
      href={ctaUrl}
      target="_blank"
      rel="nofollow sponsored noopener"
      class="affiliate-box__btn affiliate-box__btn--primary"
    >
      {ctaText}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
    </a>
    {secondaryCta && (
      <a
        href={secondaryCta.url}
        target="_blank"
        rel="nofollow sponsored noopener"
        class="affiliate-box__btn affiliate-box__btn--secondary"
      >
        {secondaryCta.text}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
      </a>
    )}
  </div>
  <p class="affiliate-box__disclosure">
    * Enlace de afiliado. Compras a traves de este enlace nos ayudan a mantener esta web, sin coste adicional para ti.
  </p>
</aside>

<style>
  .affiliate-box {
    margin: 2rem 0;
    padding: 1.5rem;
    background: linear-gradient(135deg, var(--clr-amber-bg) 0%, var(--clr-surface) 100%);
    border: 1px solid var(--clr-border);
    border-left: 4px solid var(--clr-amber);
    border-radius: var(--r-md);
    position: relative;
  }

  .affiliate-box__badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--clr-amber);
    background: rgba(232, 137, 10, 0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    margin-bottom: 0.75rem;
  }

  .affiliate-box__headline {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--clr-ink);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .affiliate-box__desc {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--clr-ink2);
    line-height: 1.6;
    margin: 0 0 1rem;
  }

  .affiliate-box__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .affiliate-box__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.65rem 1.25rem;
    border-radius: var(--r-sm);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .affiliate-box__btn--primary {
    background: var(--clr-red);
    color: #fff;
  }
  .affiliate-box__btn--primary:hover {
    background: var(--clr-red-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(200, 32, 15, 0.25);
  }

  .affiliate-box__btn--secondary {
    background: var(--clr-surface);
    color: var(--clr-ink);
    border: 1px solid var(--clr-border);
  }
  .affiliate-box__btn--secondary:hover {
    background: var(--clr-surface2);
    border-color: var(--clr-muted);
  }

  .affiliate-box__disclosure {
    font-family: var(--font-body);
    font-size: 0.7rem;
    color: var(--clr-muted);
    margin: 0.75rem 0 0;
    line-height: 1.4;
  }

  @media (max-width: 640px) {
    .affiliate-box {
      padding: 1.25rem;
    }
    .affiliate-box__actions {
      flex-direction: column;
    }
    .affiliate-box__btn {
      justify-content: center;
      width: 100%;
    }
  }
</style>
