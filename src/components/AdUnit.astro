---
export interface Props {
  slot: string;
}
const { slot } = Astro.props;
---

<div class="ad-unit" aria-label="Publicidad">
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-1887931946230317"
    data-ad-slot={slot}
    data-ad-format="auto"
    data-full-width-responsive="true"
  ></ins>
  <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
</div>

<style>
  .ad-unit {
    margin: 1.5rem 0;
    text-align: center;
    min-height: 90px;
  }
</style>
