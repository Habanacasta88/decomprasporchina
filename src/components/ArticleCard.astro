---
interface Props {
  title: string;
  slug: string;
  excerpt?: string;
  featuredImage?: string;
  date?: string;
}

const { title, slug, excerpt, featuredImage, date } = Astro.props;
const formattedDate = date ? new Date(date).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' }) : '';
---

<article class="card">
  {featuredImage && (
    <a href={`/${slug}`} class="card-img">
      <img src={featuredImage} alt={title} loading="lazy" width="640" height="360" />
    </a>
  )}
  <div class="card-body">
    <h3><a href={`/${slug}`}>{title}</a></h3>
    {excerpt && <p>{excerpt}</p>}
    {formattedDate && <time datetime={date}>{formattedDate}</time>}
  </div>
</article>
