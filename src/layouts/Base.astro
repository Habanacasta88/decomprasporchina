---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  schema?: object | object[];
  noindex?: boolean;
  ogType?: string;
  prevUrl?: string;
  nextUrl?: string;
  articlePublished?: string;
  articleModified?: string;
  articleAuthor?: string;
}

const {
  title,
  description = 'Tu guía de referencia para comprar en tiendas chinas: AliExpress, Shein, TEMU y más. Ropa, tecnología, calzado y accesorios baratos con análisis y reseñas.',
  ogImage,
  canonicalUrl,
  schema,
  noindex = false,
  ogType = 'website',
  prevUrl,
  nextUrl,
  articlePublished,
  articleModified,
  articleAuthor = 'De Compras por China',
} = Astro.props;

const siteUrl = 'https://decomprasporchina.com';
const fullCanonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : siteUrl + ogImage)
  : siteUrl + '/og-default.jpg';
const ogImageType = resolvedOgImage.endsWith('.png') ? 'image/png'
  : resolvedOgImage.endsWith('.svg') ? 'image/svg+xml'
  : 'image/jpeg';
const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];

const navLinks = [
  { href: '/categoria/tiendas-chinas', label: 'Tiendas' },
  { href: '/categoria/ropa', label: 'Ropa' },
  { href: '/categoria/accesorios', label: 'Accesorios' },
  { href: '/categoria/tecnologia', label: 'Tecnología' },
  { href: '/categoria/calzado', label: 'Calzado' },
  { href: '/categoria/deporte', label: 'Deporte' },
  { href: '/blog', label: 'Blog' },
];

const catChips = [
  { href: '/categoria/tiendas-chinas', emoji: '🛒', label: 'Tiendas Chinas' },
  { href: '/categoria/ropa', emoji: '👗', label: 'Ropa' },
  { href: '/categoria/accesorios', emoji: '👜', label: 'Accesorios' },
  { href: '/categoria/tecnologia', emoji: '📱', label: 'Tecnología' },
  { href: '/categoria/calzado', emoji: '👟', label: 'Calzado' },
  { href: '/categoria/deporte', emoji: '⚽', label: 'Deporte' },
  { href: '/categoria/xiaomi', emoji: '🔋', label: 'Xiaomi' },
  { href: '/categoria/blog', emoji: '📝', label: 'Blog' },
];
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={fullCanonical} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}
  {prevUrl && <link rel="prev" href={siteUrl + prevUrl} />}
  {nextUrl && <link rel="next" href={siteUrl + nextUrl} />}

  <!-- Preconnect for fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={fullCanonical} />
  <meta property="og:site_name" content="De Compras por China" />
  <meta property="og:locale" content="es_ES" />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type"   content={ogImageType} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedOgImage} />

  <!-- Article metadata -->
  {articlePublished && <meta property="article:published_time" content={articlePublished} />}
  {articleModified  && <meta property="article:modified_time"  content={articleModified} />}
  {articleAuthor   && ogType === 'article' && <meta property="article:author" content={articleAuthor} />}

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Schema.org -->
  {schemas.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}

  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1887931946230317" crossorigin="anonymous"></script>
</head>
<body>

  <!-- ===== HEADER ===== -->
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="site-logo">
        <div class="logo-icon">中</div>
        <div class="logo-text">
          De Compras por China
          <span>Guía de tiendas chinas</span>
        </div>
      </a>

      <nav class="main-nav" id="mainNav" aria-label="Navegación principal">
        {navLinks.map(l => (
          <a href={l.href}>{l.label}</a>
        ))}
      </nav>

      <button
        class="search-toggle"
        id="searchToggle"
        aria-label="Abrir buscador"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        Buscar
        <kbd>⌘K</kbd>
      </button>

      <button class="nav-toggle" aria-label="Abrir menú" id="navToggle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" id="iconMenu">
          <path d="M3 12h18M3 6h18M3 18h18" />
        </svg>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" id="iconClose" style="display:none">
          <path d="M18 6L6 18M6 6l12 12" />
        </svg>
      </button>
    </div>
  </header>

  <!-- Category strip -->
  <div class="cat-strip">
    <div class="cat-strip-inner">
      {catChips.map(c => (
        <a href={c.href} class="cat-chip">
          <span class="cat-chip-emoji">{c.emoji}</span>
          {c.label}
        </a>
      ))}
    </div>
  </div>

  <!-- ===== SEARCH OVERLAY ===== -->
  <div class="search-overlay" id="searchOverlay" role="dialog" aria-modal="true" aria-label="Buscador">
    <div class="search-box">
      <div class="search-box-header">
        <span class="search-icon-wrap">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </span>
        <input
          type="search"
          id="searchInput"
          class="search-input"
          placeholder="Buscar artículos… (ej: AliExpress, Shein, TEMU)"
          autocomplete="off"
        />
        <button class="search-close" id="searchClose" aria-label="Cerrar">ESC</button>
      </div>
      <ul class="search-results" id="searchResults"></ul>
    </div>
  </div>

  <!-- ===== MAIN ===== -->
  <main>
    <slot />
  </main>

  <!-- ===== FOOTER ===== -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-top">
        <div class="footer-brand">
          <a href="/" class="footer-logo">
            <div class="logo-icon">中</div>
            <div class="logo-text">
              De Compras por China
              <span>Guía de tiendas chinas</span>
            </div>
          </a>
          <p class="footer-tagline">Tu referencia para comprar en AliExpress, Shein, TEMU y las mejores tiendas chinas.</p>
        </div>
        <div class="footer-grid">
          <div class="footer-col">
            <h4>Categorías</h4>
            <a href="/categoria/tiendas-chinas">🛒 Tiendas Chinas</a>
            <a href="/categoria/ropa">👗 Ropa</a>
            <a href="/categoria/accesorios">👜 Accesorios</a>
            <a href="/categoria/tecnologia">📱 Tecnología</a>
            <a href="/categoria/calzado">👟 Calzado</a>
            <a href="/categoria/deporte">⚽ Deporte</a>
            <a href="/categoria/xiaomi">🔋 Xiaomi</a>
          </div>
          <div class="footer-col">
            <h4>Tiendas</h4>
            <a href="/aliexpress/">AliExpress</a>
            <a href="/importar-de-china-2/">Importar de China</a>
            <a href="/11-del-11-aliexpress/">11/11 AliExpress</a>
            <a href="/vender-en-aliexpress-plaza/">Vender en AliExpress</a>
            <a href="/blog">Todos los artículos</a>
          </div>
          <div class="footer-col">
            <h4>Sitio</h4>
            <a href="/sobre-nosotros/">Sobre nosotros</a>
            <a href="/contactar/">Contactar</a>
            <a href="/mapa-del-sitio/">Mapa del sitio</a>
            <a href="/aviso-legal/">Aviso Legal</a>
            <a href="/politica-de-privacidad/">Privacidad</a>
            <a href="/politica-de-cookies/">Cookies</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <span>&copy; {new Date().getFullYear()} decomprasporchina.com</span>
        <span>Sitio afiliado a Amazon · Sin coste adicional para ti</span>
      </div>
    </div>
  </footer>

  <!-- Scroll to top -->
  <button id="scrollTop" class="scroll-top" aria-label="Volver arriba">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <path d="M18 15l-6-6-6 6"/>
    </svg>
  </button>

  <script>
    // Nav toggle
    const navToggle = document.getElementById('navToggle');
    const mainNav = document.getElementById('mainNav');
    const iconMenu = document.getElementById('iconMenu');
    const iconClose = document.getElementById('iconClose');

    navToggle?.addEventListener('click', () => {
      const open = mainNav?.classList.toggle('active');
      if (iconMenu) iconMenu.style.display = open ? 'none' : '';
      if (iconClose) iconClose.style.display = open ? '' : 'none';
    });

    // Hide broken images gracefully (missing wp-content/uploads imgs)
    document.querySelectorAll<HTMLImageElement>('.article-content img').forEach(img => {
      img.addEventListener('error', function(this: HTMLImageElement) {
        this.style.display = 'none';
        // If parent <p> or <figure> only contained this image, hide it too
        const p = this.parentElement;
        if (p && (p.tagName === 'P' || p.tagName === 'FIGURE') && p.textContent?.trim() === '') {
          p.style.display = 'none';
        }
      });
    });

    // Close nav on link click (mobile)
    mainNav?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        mainNav.classList.remove('active');
        if (iconMenu) iconMenu.style.display = '';
        if (iconClose) iconClose.style.display = 'none';
      });
    });

    // Scroll to top
    const scrollBtn = document.getElementById('scrollTop');
    window.addEventListener('scroll', () => {
      if (scrollBtn) scrollBtn.style.opacity = window.scrollY > 400 ? '1' : '0';
    }, { passive: true });
    scrollBtn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

    // Search overlay
    const searchToggle = document.getElementById('searchToggle');
    const searchOverlay = document.getElementById('searchOverlay');
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const searchResults = document.getElementById('searchResults');
    const searchClose = document.getElementById('searchClose');

    let posts: { title: string; slug: string; excerpt: string }[] = [];

    const openSearch = async () => {
      searchOverlay?.classList.add('active');
      searchInput?.focus();
      if (posts.length === 0) {
        try {
          const r = await fetch('/search-index.json');
          posts = await r.json();
        } catch {}
      }
    };

    const closeSearch = () => {
      searchOverlay?.classList.remove('active');
      if (searchInput) searchInput.value = '';
      if (searchResults) searchResults.innerHTML = '';
    };

    searchToggle?.addEventListener('click', openSearch);
    searchClose?.addEventListener('click', closeSearch);
    searchOverlay?.addEventListener('click', (e) => { if (e.target === searchOverlay) closeSearch(); });

    // ⌘K / Ctrl+K shortcut
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeSearch();
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        openSearch();
      }
    });

    searchInput?.addEventListener('input', () => {
      const q = searchInput.value.toLowerCase().trim();
      if (!searchResults) return;
      if (q.length < 2) { searchResults.innerHTML = ''; return; }
      const matches = posts
        .filter(p => p.title.toLowerCase().includes(q) || p.excerpt.toLowerCase().includes(q))
        .slice(0, 8);
      if (matches.length === 0) {
        searchResults.innerHTML = `<li class="search-noresult">Sin resultados para "${searchInput.value}"</li>`;
      } else {
        searchResults.innerHTML = matches.map(p =>
          `<li><a href="/${p.slug}"><span>${p.title}</span><span>${p.excerpt}</span></a></li>`
        ).join('');
      }
    });
  </script>
</body>
</html>
