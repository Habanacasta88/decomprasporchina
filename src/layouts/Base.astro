---
import '../styles/global.css';
import '@fontsource-variable/inter';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  schema?: object | object[];
  noindex?: boolean;
  ogType?: string;
  prevUrl?: string;
  nextUrl?: string;
  // Article-specific OG metadata
  articlePublished?: string;
  articleModified?: string;
  articleAuthor?: string;
}

const {
  title,
  description = 'Tu guía de referencia para comprar en tiendas chinas: AliExpress, Shein, TEMU y más. Ropa, tecnología, calzado y accesorios baratos con análisis y reseñas.',
  ogImage,
  canonicalUrl,
  schema,
  noindex = false,
  ogType = 'website',
  prevUrl,
  nextUrl,
  articlePublished,
  articleModified,
  articleAuthor = 'De Compras por China',
} = Astro.props;

const siteUrl = 'https://decomprasporchina.com';
const fullCanonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : siteUrl + ogImage)
  : siteUrl + '/og-default.jpg';
const ogImageType = resolvedOgImage.endsWith('.png') ? 'image/png'
  : resolvedOgImage.endsWith('.svg') ? 'image/svg+xml'
  : 'image/jpeg';
const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={fullCanonical} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}
  {prevUrl && <link rel="prev" href={siteUrl + prevUrl} />}
  {nextUrl && <link rel="next" href={siteUrl + nextUrl} />}

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={fullCanonical} />
  <meta property="og:site_name" content="De Compras por China" />
  <meta property="og:locale" content="es_ES" />
  <meta property="og:image" content={resolvedOgImage} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedOgImage} />

  <!-- Open Graph article metadata -->
  {articlePublished && <meta property="article:published_time" content={articlePublished} />}
  {articleModified  && <meta property="article:modified_time"  content={articleModified} />}
  {articleAuthor   && ogType === 'article' && <meta property="article:author" content={articleAuthor} />}

  <!-- OG image dimensions (1200×630 standard) -->
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type"   content={ogImageType} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts: preload critical woff2 then let fontsource handle the rest -->

  <!-- Schema.org -->
  {schemas.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}

  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1887931946230317" crossorigin="anonymous"></script>
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="site-logo">
        <span>De Compras por China</span>
      </a>

      <button class="nav-toggle" aria-label="Abrir menú" id="navToggle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 12h18M3 6h18M3 18h18" />
        </svg>
      </button>

      <nav class="main-nav" id="mainNav">
        <a href="/">Inicio</a>
        <a href="/categoria/tiendas-chinas">Tiendas Chinas</a>
        <a href="/categoria/ropa">Ropa</a>
        <a href="/categoria/accesorios">Accesorios</a>
        <a href="/categoria/tecnologia">Tecnología</a>
        <a href="/categoria/calzado">Calzado</a>
        <a href="/categoria/deporte">Deporte</a>
        <a href="/blog">Blog</a>
      </nav>

      <button class="search-toggle" id="searchToggle" aria-label="Buscar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
    </div>
  </header>

  <!-- Search overlay -->
  <div class="search-overlay" id="searchOverlay" role="dialog" aria-modal="true" aria-label="Buscador">
    <div class="search-box">
      <button class="search-close" id="searchClose" aria-label="Cerrar búsqueda">✕</button>
      <input
        type="search"
        id="searchInput"
        class="search-input"
        placeholder="Buscar… (ej: AliExpress, Shein, ropa china)"
        autocomplete="off"
      />
      <ul class="search-results" id="searchResults"></ul>
    </div>
  </div>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>Categorías</h4>
          <a href="/categoria/tiendas-chinas">Tiendas Chinas</a>
          <a href="/categoria/ropa">Ropa</a>
          <a href="/categoria/accesorios">Accesorios</a>
          <a href="/categoria/tecnologia">Tecnología</a>
          <a href="/categoria/calzado">Calzado</a>
          <a href="/categoria/deporte">Deporte</a>
          <a href="/categoria/blog">Blog</a>
          <a href="/categoria/xiaomi">Xiaomi</a>
        </div>
        <div class="footer-col">
          <h4>Tiendas populares</h4>
          <a href="/blog">Todos los artículos</a>
          <a href="/importar-de-china-2">Importar de China</a>
          <a href="/11-del-11-aliexpress">11/11 AliExpress</a>
          <a href="/vender-en-aliexpress-plaza">Vender en AliExpress</a>
          <a href="/de-compras-por-china">Sobre nosotros</a>
        </div>
        <div class="footer-col">
          <h4>Sitio</h4>
          <a href="/contactar">Contactar</a>
          <a href="/politica-de-privacidad">Política de privacidad</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} decomprasporchina.com — Tu guía para comprar en tiendas chinas.</p>
      </div>
    </div>
  </footer>

  <!-- Scroll to top button -->
  <button id="scrollTop" class="scroll-top" aria-label="Volver arriba" title="Volver arriba">↑</button>

  <script>
    // Nav toggle
    document.getElementById('navToggle')?.addEventListener('click', () => {
      document.getElementById('mainNav')?.classList.toggle('active');
    });

    // Scroll to top
    const btn = document.getElementById('scrollTop');
    window.addEventListener('scroll', () => {
      if (btn) btn.style.opacity = window.scrollY > 400 ? '1' : '0';
    }, { passive: true });
    btn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

    // Search overlay
    const searchToggle = document.getElementById('searchToggle');
    const searchOverlay = document.getElementById('searchOverlay');
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const searchResults = document.getElementById('searchResults');
    const searchClose = document.getElementById('searchClose');

    let posts: { title: string; slug: string; excerpt: string }[] = [];

    searchToggle?.addEventListener('click', async () => {
      searchOverlay?.classList.add('active');
      searchInput?.focus();
      if (posts.length === 0) {
        try {
          const r = await fetch('/search-index.json');
          posts = await r.json();
        } catch {}
      }
    });

    searchClose?.addEventListener('click', () => {
      searchOverlay?.classList.remove('active');
      if (searchInput) searchInput.value = '';
      if (searchResults) searchResults.innerHTML = '';
    });

    searchOverlay?.addEventListener('click', (e) => {
      if (e.target === searchOverlay) searchClose?.click();
    });

    searchInput?.addEventListener('input', () => {
      const q = searchInput.value.toLowerCase().trim();
      if (!searchResults) return;
      if (q.length < 2) { searchResults.innerHTML = ''; return; }
      const matches = posts
        .filter(p => p.title.toLowerCase().includes(q) || p.excerpt.toLowerCase().includes(q))
        .slice(0, 8);
      if (matches.length === 0) {
        searchResults.innerHTML = '<li class="search-noresult">Sin resultados para "' + searchInput.value + '"</li>';
      } else {
        searchResults.innerHTML = matches.map(p =>
          `<li><a href="/${p.slug}">${p.title}</a><span>${p.excerpt}</span></li>`
        ).join('');
      }
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') searchClose?.click();
    });
  </script>
</body>
</html>
